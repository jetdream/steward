# Copy to .env for local development (.env is gitignored).
# `.coder/setup.sh` generates .env from this file and fills in secrets + URLs.
# To provision the dev infra manually: `npm run infra:up` (see README).

# ── Postgres + pgvector (.coder/postgres) — user/password/main on localhost:5432 (ARC-4)
DATABASE_URL=postgres://user:password@localhost:5432/main

# ── Blob storage: dev = MinIO (.coder/minio), the S3-compatible adapter for the
#    ADR-0003 blob port (prod = Cloudflare R2).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=steward-dev
S3_ACCESS_KEY=steward
S3_SECRET_KEY=stewardpassword

# ── OpenTelemetry → Grafana LGTM (.coder/grafana) — dev observability (CLAUDE.md)
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Auth (BetterAuth, SEC-7) — setup.sh writes a real secret into .env
BETTER_AUTH_SECRET=replace-me-in-.env
