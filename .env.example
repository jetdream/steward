# Copy to .env for local development (.env is gitignored).
# `.coder/setup.sh` generates .env from this file and fills in secrets + URLs.
# To provision the dev infra manually: `npm run infra:up` (see README).

# ── Postgres + pgvector (.coder/postgres) — user/password/main on localhost:5432 (ARC-4)
DATABASE_URL=postgres://user:password@localhost:5432/main

# ── Blob storage: dev = MinIO (.coder/minio), the S3-compatible adapter for the
#    ADR-0003 blob port (prod = Cloudflare R2).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=steward-dev
S3_ACCESS_KEY=steward
S3_SECRET_KEY=stewardpassword

# ── OpenTelemetry → Grafana LGTM (.coder/grafana) — dev observability (CLAUDE.md)
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Auth (BetterAuth, SEC-7) — setup.sh writes a real secret into .env
BETTER_AUTH_SECRET=replace-me-in-.env
BETTER_AUTH_URL=http://localhost:3001
# Google sign-in (production). Leave blank for the dev email-only flow.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LLM / embeddings: Google Vertex AI / Gemini (ADR-0008, DEC-40), behind the
#    ADR-0003 LLM port. Set VERTEX_AI_KEY to use the real provider (Gemini
#    extraction + gemini-embedding-2 @ 1536). Leave BLANK for the deterministic
#    keyless dev stub — self-contained dev + CI run without a GCP account.
VERTEX_AI_KEY=
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1

# ── cortex semantic-find (DEV TOOLING, not the app): embeds the .spec docs graph
#    for `cortex graph find` (index committed under .spec/.index; config in
#    .spec/registry.yaml `semantic-find`). Set to run `cortex graph index`; find
#    stays lexical without it. This is the project's own spec text, not org data.
VERCEL_AI_GW_EMBED_KEY=
