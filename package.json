{
  "name": "steward",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "shared",
    "backend",
    "client",
    "news"
  ],
  "scripts": {
    "docs:check": "cortex-docs-check",
    "typecheck": "tsc -p shared/tsconfig.json && tsc -p backend/tsconfig.json && tsc -p client/tsconfig.json && tsc -p news/tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "gate": "npm run docs:check && npm run typecheck && npm run lint",
    "test": "tsx --env-file-if-exists=.env --test \"{shared,backend,client,news}/src/**/*.test.ts\"",
    "eval": "tsx --env-file-if-exists=.env backend/src/eval/run.ts",
    "eval:gate": "tsx backend/src/eval/gate.ts",
    "db:generate": "cd backend && drizzle-kit generate",
    "db:migrate": "cd backend && drizzle-kit migrate",
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch backend/src/server.ts",
    "dev:web": "npm run dev -w @steward/client",
    "build:web": "npm run build -w @steward/client",
    "infra:up": "docker compose -f .coder/postgres/docker-compose.yml up -d && docker compose -f .coder/minio/docker-compose.yml up -d && docker compose -f .coder/grafana/docker-compose.yml up -d",
    "infra:down": "docker compose -f .coder/postgres/docker-compose.yml down && docker compose -f .coder/minio/docker-compose.yml down && docker compose -f .coder/grafana/docker-compose.yml down",
    "dev:playwright:build": "docker compose -f .coder/playwright/docker-compose.yml build",
    "dev:playwright": "docker compose -f .coder/playwright/docker-compose.yml up -d",
    "dev:playwright:stop": "docker compose -f .coder/playwright/docker-compose.yml down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "cortex": "github:DiffCo/cortex#v0.21.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
